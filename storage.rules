rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function currentUser() {
      return userDoc(request.auth.uid).data;
    }

    function clubDoc(clubId) {
      return firestore.get(/databases/(default)/documents/clubs/$(clubId));
    }

    function eventDoc(eventId) {
      return firestore.get(/databases/(default)/documents/events/$(eventId));
    }

    function sameCollegeAsClub(clubId) {
      return isSignedIn() && currentUser().college_name == clubDoc(clubId).data.college_name;
    }

    function isClubManager(clubId) {
      return isSignedIn() && (
        clubDoc(clubId).data.club_master_id == request.auth.uid ||
        clubDoc(clubId).data.president_id == request.auth.uid ||
        request.auth.uid in clubDoc(clubId).data.organizers
      );
    }

    function validImage() {
      return request.resource == null ||
        (request.resource.size < 5 * 1024 * 1024 &&
         request.resource.contentType.matches('image/.*'));
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId && validImage();
    }

    match /clubs/{clubId}/{allPaths=**} {
      allow read: if sameCollegeAsClub(clubId);
      allow write: if isClubManager(clubId) && validImage();
    }

    match /events/{eventId}/{allPaths=**} {
      allow read: if isSignedIn() && currentUser().college_name == eventDoc(eventId).data.college_name;
      allow write: if isClubManager(eventDoc(eventId).data.club_id) && validImage();
    }

    match /announcements/{announcementId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && validImage();
    }
  }
}
