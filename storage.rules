rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function currentUser() {
      return userDoc(request.auth.uid).data;
    }

    function clubDoc(clubId) {
      return firestore.get(/databases/(default)/documents/clubs/$(clubId));
    }

    function eventDoc(eventId) {
      return firestore.get(/databases/(default)/documents/events/$(eventId));
    }

    function sameTenant(data) {
      return isSignedIn() && (
        data.institution_id == currentUser().institution_id ||
        (
          (!('institution_id' in data) || data.institution_id == null) &&
          data.college_name == currentUser().college_name
        )
      );
    }

    function sameTenantAsUser(userId) {
      return isSignedIn() && sameTenant(userDoc(userId).data);
    }

    function sameTenantAsClub(clubId) {
      return isSignedIn() && sameTenant(clubDoc(clubId).data);
    }

    function sameTenantAsEvent(eventId) {
      return isSignedIn() && sameTenant(eventDoc(eventId).data);
    }

    function isClubManager(clubId) {
      return isSignedIn() && (
        clubDoc(clubId).data.club_master_id == request.auth.uid ||
        clubDoc(clubId).data.president_id == request.auth.uid ||
        request.auth.uid in clubDoc(clubId).data.organizers
      );
    }

    function validImageForInstitution(institutionId) {
      return request.resource != null &&
        request.resource.size < 3 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.metadata.institution_id == institutionId &&
        request.resource.metadata.owner_id == request.auth.uid;
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if sameTenantAsUser(userId);
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        validImageForInstitution(currentUser().institution_id);
    }

    match /clubs/{clubId}/{allPaths=**} {
      allow read: if sameTenantAsClub(clubId);
      allow write: if isClubManager(clubId) &&
        sameTenantAsClub(clubId) &&
        validImageForInstitution(clubDoc(clubId).data.institution_id);
    }

    match /events/{eventId}/{allPaths=**} {
      allow read: if sameTenantAsEvent(eventId);
      allow write: if isClubManager(eventDoc(eventId).data.club_id) &&
        sameTenantAsEvent(eventId) &&
        validImageForInstitution(eventDoc(eventId).data.institution_id);
    }

    match /announcements/{announcementId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
